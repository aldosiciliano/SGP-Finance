# Variables de entorno para SGP Finance

# Base de datos
DATABASE_URL=postgresql://sgp_user:sgp_password@localhost:5432/sgp_finance

# Autenticación
SECRET_KEY=your-super-secret-token-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Agregar el ID de la extensión Chrome después de cargarla
# Formato: http://localhost:5173,chrome-extension://YOUR_EXTENSION_ID_HERE
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Frontend
VITE_API_URL=http://localhost:8000
